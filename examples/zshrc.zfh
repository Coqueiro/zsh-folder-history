# Temporary test config for zsh-folder-history.
# Source it from an interactive zsh shell:
#   source ~/Github/zsh-folder-history/examples/zshrc.zfh

export ZSH_FOLDER_HISTORY_FILE="${XDG_STATE_HOME:-$HOME/.local/state}/zsh-folder-history-test/directories"
export ZSH_FOLDER_HISTORY_ENABLE_ALIASES=1

source "$HOME/Github/zsh-folder-history/zsh-folder-history.plugin.zsh"

# Match current macOS behavior.
zfh bindkey '^H'
